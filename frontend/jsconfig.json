{
    "compilerOptions": {
      "jsx": "react-jsx",
      "baseUrl": ".",
      "paths": {
        "@/*": ["src/*"]
      },
      "module": "ESNext",
      "moduleResolution": "bundler",
      "target": "ESNext",
      "strict": false,
      "noEmit": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules"]
  }